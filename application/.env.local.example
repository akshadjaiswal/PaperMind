# Required — get your free key at console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# Optional but recommended — prevents Semantic Scholar 429 rate limit errors
# Free key: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=your_s2_api_key_here

# Optional — used for Unpaywall PDF discovery (defaults to placeholder if not set)
UNPAYWALL_EMAIL=your_email@example.com
